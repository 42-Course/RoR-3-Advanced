<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Acme</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap 5 + Bootstrap Icons (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" crossorigin="anonymous">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100 bg-app">
    <nav class="navbar navbar-expand-lg navbar-brand-gradient sticky-top shadow-sm">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 fw-bold" do %>
          <span class="brand-badge"><i class="bi bi-hexagon-fill"></i></span>
          <span>Acme</span>
        <% end %>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
            <% if user_signed_in? %>
              <li class="nav-item d-flex align-items-center me-lg-2">
                <span class="nav-greeting">
                  <i class="bi bi-person-circle me-1"></i>Hi, <%= current_user.name %>
                </span>
              </li>
              <li class="nav-item">
                <%= link_to edit_user_registration_path, class: "nav-link px-3" do %>
                  <i class="bi bi-gear me-1"></i>My profile
                <% end %>
              </li>
              <li class="nav-item ms-lg-1">
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "btn btn-outline-light btn-sm rounded-pill px-3" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Sign in", new_user_session_path, class: "nav-link px-3" %>
              </li>
              <li class="nav-item ms-lg-1">
                <%= link_to "Sign up", new_user_registration_path, class: "btn btn-light btn-sm rounded-pill px-3 fw-semibold text-primary-emphasis" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <% if flash.any? %>
      <div class="container mt-3">
        <% flash.each do |type, message| %>
          <div class="alert <%= flash_bootstrap_class(type) %> alert-dismissible fade show d-flex align-items-center shadow-sm rounded-3" role="alert">
            <i class="bi <%= flash_bootstrap_icon(type) %> fs-5 me-2"></i>
            <div><%= message %></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="d-flex flex-grow-1">
      <%= yield %>
    </main>

    <footer class="site-footer py-4 mt-auto">
      <div class="container text-center small">
        <span class="text-muted">&copy; <%= Date.current.year %> Acme &middot; Crafted with</span>
        <i class="bi bi-heart-fill text-danger mx-1"></i>
        <span class="text-muted">by pulgamecanica | w/ Ruby on Rails</span>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </body>
</html>
