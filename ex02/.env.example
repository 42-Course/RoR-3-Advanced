# ---------------------------------------------------------------------------
# Template environment file. Copy to `.env` and fill in real values:
#   cp .env.example .env
# ---------------------------------------------------------------------------

# PostgreSQL container credentials (used by the `db` service and by Rails)
POSTGRES_USER=acme
POSTGRES_PASSWORD=change_me
POSTGRES_DB=acme_development

# How Rails reaches the database.
# Inside docker-compose the host is the service name `db`.
DATABASE_HOST=db
DATABASE_PORT=5432

# Rails
RAILS_MAX_THREADS=5
