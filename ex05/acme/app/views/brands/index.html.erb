<div class="section-head">
  <h1>Brands</h1>
  <span class="meta"><%= pluralize(@brands.size, "brand") %></span>
</div>

<div class="catalog">
  <% @brands.each do |brand| %>
    <article class="brand-card">
      <div class="card-media">
        <%= link_to brand do %>
          <% if brand.avatar? %>
            <%= image_tag brand.avatar_url(:thumb), alt: brand.name, loading: "lazy" %>
          <% else %>
            <span class="no-image">NO IMAGE</span>
          <% end %>
        <% end %>
      </div>
      <div class="card-body">
        <div class="card-title"><%= link_to brand.name, brand %></div>
        <div class="card-brand"><%= pluralize(brand.products.size, "product") %></div>
      </div>
    </article>
  <% end %>
</div>
