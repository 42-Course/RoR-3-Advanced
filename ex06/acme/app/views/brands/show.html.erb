<div class="section-head">
  <div class="d-flex align-items-center gap-3">
    <% if @brand.avatar? %>
      <%= image_tag @brand.avatar_url(:thumb), alt: @brand.name,
            style: "width:64px;height:64px;object-fit:cover;border:1px solid var(--line);" %>
    <% end %>
    <h1 class="mb-0"><%= @brand.name %></h1>
  </div>
  <span class="meta"><%= pluralize(@brand.products.size, "product") %></span>
</div>

<div class="catalog">
  <%= render @brand.products.order(:name) %>
</div>

<div class="mt-4"><%= link_to "← All brands", brands_path %></div>
