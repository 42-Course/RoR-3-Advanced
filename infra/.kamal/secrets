# Secrets for the shared infra project. Evaluated as shell — NO raw
# credentials here. Git-ignored.

# Only needed if the placeholder image were ever pulled; harmless otherwise.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Shared Postgres password. MUST match the POSTGRES_PASSWORD every exercise
# uses to connect. Single source of truth: ex00/.env (export to override).
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-$(grep -E '^POSTGRES_PASSWORD=' ../ex00/.env | cut -d= -f2-)}
